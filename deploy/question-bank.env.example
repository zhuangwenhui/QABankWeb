# 复制到 /etc/question-bank.env 并 chmod 600、chown root:deploy
APP_ENV=production
# 用 python3 -c "import secrets; print(secrets.token_hex(32))" 生成后填入(勿留 CHANGEME)
SECRET_KEY=CHANGEME
USE_X_ACCEL=1
# 首次部署创建管理员时临时使用,用后删除本行
# ADMIN_INITIAL_PASSWORD=

# —— 运维加固:异地备份 QB_OFFSITE_REMOTE / 错误心跳 QB_HEARTBEAT_URL / QB_ERROR_LOG ——
# 这三个供 cron 脚本(backup.sh / alert_heartbeat.sh),不属于 app 本身;
# 配在 deploy 用户的 crontab 顶部(见 deploy/crontab.example),而非本文件。

# —— 采点判题引擎(未接模型前留空 = 走占位 stub,零外部调用)——
# 设 ANTHROPIC_API_KEY 即启用 Claude 多模态阅卷(可选 ANTHROPIC_GRADER_MODEL,默认 claude-opus-4-8)
# ANTHROPIC_API_KEY=
